# Add these values in Netlify: Site configuration > Environment variables.
# Never commit real credentials.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_CAMPAIGNS_LIST_KEY=

# Optional. Leave the defaults for a United States (.com) Zoho account.
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_CAMPAIGNS_API_URL=https://campaigns.zoho.com

# Optional for Zoho Campaigns accounts using Topics.
ZOHO_CAMPAIGNS_TOPIC_ID=
